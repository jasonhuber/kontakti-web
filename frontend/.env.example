# Google OAuth — Web Client ID from Google Cloud Console.
# Used for:
#   - Onboarding contacts import (people.googleapis.com OAuth token flow)
#   - Linking additional Gmail accounts from Settings (GSI id_token flow)
# You can use the same Web Client ID for both VITE_GOOGLE_CLIENT_ID and
# VITE_GOOGLE_WEB_CLIENT_ID, or keep them split for clarity.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_WEB_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# VAPID public key for Web Push notifications.
# Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the *public* key here (base64url-encoded). Keep the private key on
# the backend — it's used to sign push messages.
VITE_VAPID_PUBLIC_KEY=
