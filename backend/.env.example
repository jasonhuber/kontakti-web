APP_NAME=Konataki
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=konataki
DB_USERNAME=postgres
DB_PASSWORD=

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Obsidian Integration
OBSIDIAN_VAULT_PATH=/Users/your-username/Documents/Obsidian/Personal
OBSIDIAN_CRM_FOLDER=konataki
OBSIDIAN_SYNC_ENABLED=true
OBSIDIAN_AUTO_SYNC=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Phase 2 — AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDINGS_ENABLED=false
